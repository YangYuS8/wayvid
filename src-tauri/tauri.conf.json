{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LWE",
  "identifier": "dev.lwe.app",
  "build": {
    "beforeBuildCommand": "pnpm run build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "Linux dynamic wallpaper shell for Wallpaper Engine content.",
    "targets": [
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      }
    }
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/.steam/steam/steamapps/workshop/content/**/*"
          ]
        }
      }
    },
    "windows": [
      {
        "title": "LWE",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ]
  }
}
